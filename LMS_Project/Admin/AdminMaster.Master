<%@ Master Language="C#" AutoEventWireup="true"
    CodeBehind="AdminMaster.master.cs"
    Inherits="LearningManagementSystem.Admin.AdminMaster" %>

<!DOCTYPE html>
<html>
<head runat="server">
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>LMS Admin Panel</title>

<asp:ContentPlaceHolder ID="ContentPlaceHolder1" runat="server"></asp:ContentPlaceHolder>

<link href="../assets/css/bootstrap.min.css" rel="stylesheet" />
<link href="../assets/icons/fontawesome/css/all.min.css" rel="stylesheet" />

<style>

/* ================= BASE ================= */
body {
    margin: 0;
    background: #f0f4f8;
    font-family: system-ui, -apple-system, "Segoe UI", Roboto;
}

/* ================= LAYOUT ================= */
#main-wrapper {
    display: flex;
    min-height: 100vh;
}

/* ================= SIDEBAR ================= */
.sidebar {
    width: 240px;
    background: #f0f4fa;
    border-right: 3px solid #1565c0;
    position: fixed;
    height: 100vh;
    overflow-y: auto;
    transition: .3s;
    z-index: 1200;
    transition: all 0.3s ease;
}

#main-wrapper.sidebar-collapsed .sidebar {
    width: 20px;
}

/* LOGO */
.sidebar-header {
    padding: 15px;
    text-align: center;
    border-bottom: 1px solid #e3e8f0;
    position: sticky;
    top: 0;
    background: #f0f4fa;
    z-index: 2;
}

.sidebar-logo {
    max-height: 55px;
}

/* MENU */
.sidebar-menu {
    list-style: none;
    padding: 0;
}

.sidebar-section-label {
    font-size: 10px;
    font-weight: 700;
    color: #90a4ae;
    padding: 14px 18px 4px;
    text-transform: uppercase;
}

/* LINKS */
.sidebar-menu li a {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 18px;
    text-decoration: none;
    color: #333;
    font-size: 14px;
    transition: .2s;
}

.sidebar-icon {
    width: 18px;
    color: #1976d2;
}

.sidebar-menu li a:hover {
    background: #e3f2fd;
    color: #1565c0;
}

/* ACTIVE */
.sidebar-link.active {
    background: #1565c0;
    color: #fff !important;
    position: relative;
}

.sidebar-link.active .sidebar-icon {
    color: #fff;
}

.sidebar-link.active::before {
    content: "";
    position: absolute;
    left: 0;
    width: 4px;
    height: 100%;
    background: #90caf9;
}

/* SUBMENU */
.sidebar-submenu {
    display: none;
    padding-left: 35px;
    border-left: 2px solid #e0e0e0;
}

.submenu.open .sidebar-submenu {
    display: block;
}

.right-icon {
    margin-left: auto;
    font-size: 11px;
    transition: .3s;
}

.submenu.open .right-icon {
    transform: rotate(90deg);
}

/* ================= HEADER ================= */
/*.header {
    height: 65px;
    background: linear-gradient(135deg, #1565c0, #1976d2);
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0 25px;
    position: fixed;
    left: 240px;
    right: 0;
    top: 0;
    z-index: 1000;

}*/

.header {
    min-height: 65px;
    background: linear-gradient(135deg, #1565c0, #1976d2);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 8px 20px;
    position: fixed;
    left: 240px;
    right: 0;
    top: 0;
    z-index: 1100;
    flex-wrap: wrap;
    gap: 8px;
}

/* LEFT SECTION */
.header-left {
    display: flex;
    align-items: center;
    gap: 10px;
    flex: 1;
    min-width: 180px;
}

/* CENTER (SESSION) */
.header-center {
    flex: 0 0 auto;
}

/* RIGHT ICONS */
.header-right {
    display: flex;
    align-items: center;
    gap: 12px;
}

#main-wrapper.sidebar-collapsed .header {
    left: 20px;
}

.header-title {
    color: #fff;
    font-size: 18px;
    font-weight: 700;
}

.admin-badge {
    background: rgba(255,255,255,0.2);
    color: #fff;
    padding: 3px 10px;
    border-radius: 12px;
    font-size: 11px;
    margin-left: 10px;
}

/* PROFILE */
.profile-img {
    width: 35px;
    height: 35px;
    border-radius: 50%;
    border: 2px solid #90caf9;
}

/* ================= CONTENT ================= */
.content-wrapper {
    flex: 1;
    margin-left: 240px;
    margin-top: 65px;
    transition: .3s;
    transition: all 0.3s ease;
}

.content-wrapper {
    margin-left: 240px;
    margin-top: 70px; /* increase */
}

#main-wrapper.sidebar-collapsed .content-wrapper {
    margin-left: 50px;
}

.content-body {
    padding: 25px;
}

/* ================= RESPONSIVE ================= */
@media(max-width:992px){
    .sidebar {
        left: -260px;
    }

    #main-wrapper.sidebar-collapsed .sidebar {
        left: 0;
    }

    .header {
        left: 0 !important;
    }

    .content-wrapper {
        margin-left: 0 !important;
    }
}

/* ================= OVERLAY ================= */
.sidebar-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0,0,0,0.4);
    z-index: 1150;
    display: none;
}

/* Show overlay */
#main-wrapper.sidebar-open .sidebar-overlay {
    display: block;
}

/* ================= RESPONSIVE ================= */
@media (max-width: 992px) {

    .sidebar {
        left: -260px;
    }

    #main-wrapper.sidebar-open .sidebar {
        left: 0;
    }

     prevent layout shift 
    .content-wrapper {
        margin-left: 0 !important;
    }

    .header {
        left: 0 !important;
    }
}

@media (max-width: 768px) {

    .header {
        flex-direction: column;
        align-items: stretch;
        height: auto;
        padding: 10px;
    }

    .header-left,
    .header-center,
    .header-right {
        width: 100%;
        justify-content: space-between;
    }

    .header-title {
        font-size: 14px;
    }

    .admin-badge {
        display: none;
    }

    #ddlGlobalSession {
        width: 100% !important;
        margin-top: 5px;
    }

    .content-wrapper {
        margin-top: 110px; /* 🔥 fix overlap */
    }
}

/* ===== HEADER FLEX FIX ===== */
.header {
    flex-wrap: wrap; /* allow wrapping */
    gap: 10px;
}

/* LEFT SECTION */
.header > div:first-child {
    flex: 1 1 auto;
    min-width: 200px;
}

/* SESSION FILTER */
.header > div:nth-child(2) {
    flex: 0 0 auto;
}

/* RIGHT ICONS */
.header ul.nav {
    flex: 0 0 auto;
}

/* MOBILE STACK */
@media (max-width: 768px) {

    .header {
        height: auto;
        padding: 10px;
        align-items: flex-start;
    }

    .header-title {
        font-size: 14px;
    }

    .admin-badge {
        display: none; /* prevent overflow */
    }

    /* STACK ELEMENTS */
    .header > div,
    .header ul.nav {
        width: 100%;
        justify-content: space-between;
    }

    /* SESSION DROPDOWN FULL WIDTH */
    #ddlGlobalSession {
        width: 100% !important;
    }

    .header ul.nav {
        justify-content: flex-end;
    }
}


</style>
</head>

<body>

