<script src="../assets/js/bootstrap.bundle.min.js"></script>

<script>
    //document.addEventListener("DOMContentLoaded", function () {

    //    const wrapper = document.getElementById("main-wrapper");

    //    document.querySelector(".collapse-sidebar").addEventListener("click", function () {
    //        wrapper.classList.toggle("sidebar-collapsed");
    //    });

    //    document.querySelectorAll(".submenu-parent").forEach(function (menu) {
    //        menu.addEventListener("click", function (e) {
    //            e.preventDefault();
    //            this.closest(".submenu").classList.toggle("open");
    //        });
    //    });

    //    const current = window.location.pathname.split("/").pop().toLowerCase();
    //    document.querySelectorAll(".sidebar-link").forEach(link => {
    //        if (link.getAttribute("href")?.toLowerCase() === current) {
    //            link.classList.add("active");
    //            const parent = link.closest(".submenu");
    //            if (parent) parent.classList.add("open");
    //        }
    //    });

    //});

    document.addEventListener("DOMContentLoaded", function () {

        const wrapper = document.getElementById("main-wrapper");
        const toggleBtn = document.querySelector(".collapse-sidebar");
        const overlay = document.querySelector(".sidebar-overlay");

        // ✅ TOGGLE
        toggleBtn.addEventListener("click", function () {

            if (window.innerWidth <= 992) {
                wrapper.classList.toggle("sidebar-open"); // MOBILE
            } else {
                wrapper.classList.toggle("sidebar-collapsed"); // DESKTOP
            }
        });

        // ✅ CLOSE ON OVERLAY CLICK
        overlay.addEventListener("click", function () {
            wrapper.classList.remove("sidebar-open");
        });

        // ✅ SUBMENU
        document.querySelectorAll(".submenu-parent").forEach(function (menu) {
            menu.addEventListener("click", function (e) {
                e.preventDefault();
                this.closest(".submenu").classList.toggle("open");
            });
        });

        // ✅ ACTIVE MENU
        const current = window.location.pathname.split("/").pop().toLowerCase();

        document.querySelectorAll(".sidebar-link").forEach(link => {
            if (link.getAttribute("href")?.toLowerCase() === current) {
                link.classList.add("active");

                const parent = link.closest(".submenu");
                if (parent) parent.classList.add("open");
            }
        });

    });
</script>

</form>
</body>
